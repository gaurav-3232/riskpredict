# ─── Database ───
DATABASE_URL=postgresql://riskpredict:riskpredict_secret@localhost:5432/riskpredict
POSTGRES_USER=riskpredict
POSTGRES_PASSWORD=riskpredict_secret
POSTGRES_DB=riskpredict

# ─── Ports (local dev) ───
POSTGRES_PORT=5433
BACKEND_PORT=8001
FRONTEND_PORT=5173

# ─── Application ───
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Storage ───
MODELS_DIR=/app/storage/models
DATASETS_DIR=/app/storage/datasets

# ─── Auth (future) ───
# JWT_SECRET=change-me-in-production
